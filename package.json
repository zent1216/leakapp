{
  "name": "leakapp-rebuild",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "deploy:firebase": "npm run build && firebase deploy",
    "deploy:pages": "npm run build && gh-pages -d dist"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest",
    "firebase": "latest",
    "lucide-react": "latest",
    "html2canvas": "latest",
    "jspdf": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "typescript": "latest",
    "vite": "latest",
    "gh-pages": "latest"
  }
}
